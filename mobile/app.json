{
  "expo": {
    "name": "Naija Market",
    "slug": "naija-market",
    "version": "1.0.0",
    "scheme": "naijamarket",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.ojobointernational.naijamarket"
    },
    "ios": {
      "bundleIdentifier": "com.ojobointernational.naijamarket"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#16a34a"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Naija Market to access your photos."
        }
      ],
      "expo-build-properties"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "120a97a3-6f34-4546-9365-da5792852b3e"
      }
    }
  }
}
