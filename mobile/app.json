{
  "expo": {
    "name": "Naija Market",
    "slug": "naija-market",
    "version": "1.0.0",
    "scheme": "naijamarket",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.yourname.naijamarket",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Naija Market to access your photos."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "120a97a3-6f34-4546-9365-da5792852b3e"
      }
    },
    "owner": "augustineojobo"
  }
}
